# Telegram (обязателен для сервиса bot и для уведомлений воркера)
BOT_TOKEN=

# Через запятую: telegram user id с кнопкой «Админка». Если переменная не задана — в коде уже есть два админа по умолчанию.
# Полная замена списка: BOT_ADMIN_TELEGRAM_IDS=6805465388,7670490295

# Как получать апдейты: polling (удобно локально) | webhook (нужен публичный HTTPS)
TELEGRAM_DELIVERY=polling

# Только webhook: полный HTTPS URL бота без слэша в конце — для setWebhook при старте bot-сервиса
# WEBHOOK_BASE_URL=https://your-domain.example

# Секрет и путь (заголовок X-Telegram-Bot-Api-Secret-Token); пустой WEBHOOK_SECRET = не проверять
# WEBHOOK_SECRET=change-me
# WEBHOOK_PATH=/webhook

# Docker: API на :8000, бот на :8080. За nginx: проксируйте POST {WEBHOOK_PATH} на bot:8080

# Mini App: публичный HTTPS origin без пути (страница — GET / на сервисе API).
# Прод (Zeabur + свой домен): https://app.example.com — тот же хост в @BotFather → Web Apps (только hostname).
# Локально без домена можно временно использовать туннель на :8000 (не для продакшена).
# Кнопка «Терминал» добавляет к URL параметр startapp=… (см. app/bot/keyboards.py).
MINI_APP_PUBLIC_URL=

# Кликер: временный бонус регена за инвайт (/start) и «онлайн» сеть в Mini App
# INVITE_REGEN_BOOST_HOURS=5
# INVITE_REGEN_BOOST_BPS=5000
# Считаем реферала онлайн, если был запрос mini API не столько секунд назад (heartbeat)
# MINI_APP_ONLINE_PRESENCE_SECONDS=180

# При true — удлинённый стартовый таймер (имитация period=launch)
LAUNCH_MODE=false

# Таймер и волны (опционально; по умолчанию 60 ч обычный режим, 72 ч при launch)
# DEFAULT_TIMER_HOURS=60
# LAUNCH_TIMER_HOURS=72
# BONUS_HOURS_PER_REFERRAL=3
# Окно иммунитета после активации из зомби (часы)
# IMMUNE_DURATION_HOURS=24
# SLEEPING_NO_SPREAD_HOURS=4
# SLEEPING_TICK_BONUS_SECONDS=30
# Предупреждение «мало времени» за N часов (отдельные сообщения; по умолчанию 2ч / 1ч / 30м / 10м)
# WARN_BEFORE_HOURS=2
# WARN_BEFORE_HOURS_1=1

# Postgres
POSTGRES_USER=virus
POSTGRES_PASSWORD=virus
POSTGRES_DB=virus
DATABASE_URL=postgresql+asyncpg://virus:virus@localhost:5432/virus
# Синхронный URL для Alembic (docker-entrypoint / локально)
DATABASE_URL_SYNC=postgresql://virus:virus@localhost:5432/virus

# Redis (с хоста к контейнеру см. REDIS_HOST_PORT в docker-compose, по умолчанию 16379)
REDIS_URL=redis://localhost:16379/0

# Celery
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Лаборатория / Фонтан: лимит единиц реагентов (ДНК+РНК+CAT) в фонтан за UTC-сутки; вес вклада
# FOUNTAIN_POUR_DAILY_UNIT_CAP=20
# REAGENT_WEIGHT_DNA=1.0
# REAGENT_WEIGHT_RNA=3.0
# REAGENT_CAT_MULT=0.25

# ── Дебаффы штамма (рандомные угрозы, лечатся через Лабу) ───────────────────
# AFFLICTION_CHECK_MINUTES=60
# AFFLICTION_COOLDOWN_HOURS=36
# AFFLICTION_DURATION_HOURS=18
# AFFLICTION_MIN_STRAIN_SIZE=4
# AFFLICTION_BASE_CHANCE=0.03
# AFFLICTION_CHANCE_CAP=0.08
# AFFLICTION_RESEARCH_DAILY_CAP=2
